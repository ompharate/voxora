# Runtime values consumed by entrypoint.sh.
# docker/docker-compose.yml can override these from docker/.env.
VITE_API_URL=http://YOUR_SERVER_IP/api/v1
VITE_WIDGET_URL=http://YOUR_SERVER_IP/interaone-widget/v1/InteraOne.js
VITE_SOCKET_URL=http://YOUR_SERVER_IP
VITE_PUBLIC_ENV=production

VITE_INTERAONE_MODE=self-hosted
VITE_INTERAONE_EE_ENABLED=false
VITE_INTERAONE_EE_MODULE_PRESENT=true
VITE_INTERAONE_LICENSE_KEY=

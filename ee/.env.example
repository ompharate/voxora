# ==============================================================================
# ENTERPRISE EDITION ENVIRONMENT VARIABLES
# ==============================================================================
# If you have purchased an Enterprise License Key, copy these variables
# and append them to your main `apps/api/.env` file. Do not run a separate
# Node process in this folder.
# ==============================================================================

# Dodo Payments (used by EE billing)
# Minimal required set:
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_PRODUCT_PRO=
DODO_PAYMENTS_PRODUCT_PROPLUS=
# Backward-compatible alias (maps to Pro+ when set):
DODO_PAYMENTS_PRODUCT_ENTERPRISE=

# Optional overrides:
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_PAYMENTS_SUCCESS_URL=http://localhost:5173/dashboard/settings/billing/success
DODO_PAYMENTS_CANCEL_URL=http://localhost:5173/dashboard/settings/billing/failed
DODO_PAYMENTS_WEBHOOK_SECRET=
# Alias supported for compatibility with Dodo docs/examples:
DODO_PAYMENTS_WEBHOOK_KEY=
